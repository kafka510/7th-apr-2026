			"name": "Authentication",
			"item": [
				{
					"name": "Request Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"api_key\": \"{{api_key}}\",\n    \"lifetime_minutes\": 60,\n    \"max_uses\": 100\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/token",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "token"]
						},
						"description": "Generate an active token from API key with brute force protection. Returns a short-lived token for enhanced security."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Extract and save the active token from the response",
									"if (pm.response.code === 200) {",
									"    try {",
									"        const responseBody = pm.response.json();",
									"        if (responseBody.success && responseBody.token) {",
									"            // Save the token to environment",
									"            pm.environment.set('active_token', responseBody.token);",
									"            ",
									"            // Also save expiration and other details for reference",
									"            pm.environment.set('token_expires_at', responseBody.expires_at);",
									"            pm.environment.set('token_created_at', responseBody.created_at);",
									"            pm.environment.set('token_lifetime_minutes', responseBody.lifetime_minutes);",
									"            ",
									"            // Show success message",
									"            console.log('✓ Token successfully extracted and saved!');",
									"            console.log('Token expires at: ' + responseBody.expires_at);",
									"            console.log('Active token is now available for subsequent requests');",
									"        } else {",
									"            console.log('❌ Response does not contain a token');",
									"        }",
									"    } catch (error) {",
									"        console.log('❌ Error parsing response: ' + error);",
									"    }",
									"} else {",
									"    console.log('❌ Request failed with status: ' + pm.response.code);",
									"    console.log('Response: ' + pm.response.text());",
									"}"
								]
							}
						}
					],
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"api_key\": \"your-api-key-here\",\n    \"lifetime_minutes\": 60,\n    \"max_uses\": 100\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/v1/auth/token",
									"host": ["{{base_url}}"],
									"path": ["api", "v1", "auth", "token"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"cookie": [],
							"body": "{\n    \"success\": true,\n    \"token\": \"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...\",\n    \"expires_at\": \"2025-01-01T12:00:00Z\",\n    \"lifetime_minutes\": 60,\n    \"max_uses\": 100,\n    \"created_at\": \"2025-01-01T11:00:00Z\"\n}"
