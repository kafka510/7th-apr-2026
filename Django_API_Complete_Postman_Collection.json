	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// ====================================",
					"// PRE-REQUEST SCRIPT - Global Setup",
					"// ====================================",
					"",
					"// Check if active token is set and warn if close to expiration",
					"const activeToken = pm.environment.get('active_token');",
					"const tokenExpiresAt = pm.environment.get('token_expires_at');",
					"",
					"if (activeToken && tokenExpiresAt) {",
					"    const expirationTime = new Date(tokenExpiresAt);",
					"    const currentTime = new Date();",
					"    const minutesUntilExpiry = (expirationTime - currentTime) / (1000 * 60);",
					"    ",
					"    if (minutesUntilExpiry < 5) {",
					"        console.log('⚠️  WARNING: Active token expires in ' + Math.round(minutesUntilExpiry) + ' minutes!');",
					"        console.log('⚠️  Consider running \"Request Token\" again to get a fresh token');",
					"    } else if (minutesUntilExpiry > 0) {",
					"        console.log('✓ Active token is valid (expires in ' + Math.round(minutesUntilExpiry) + ' minutes)');",
					"    } else {",
					"        console.log('❌ Active token has EXPIRED! Please run \"Request Token\" again');",
					"    }",
					"} else if (pm.request.name !== 'Request Token' && pm.request.name !== 'List Tables (Bearer Token)' && pm.request.name !== 'List Tables (X-API-Key Header)' && pm.request.name !== 'List Tables (Query Parameter)') {",
					"    console.log('ℹ️  No active token found. Run \"Request Token\" first to get a token');",
					"}",
					"",
					"// Auto-generate CSRF token if not set (for admin endpoints)",
					"if (!pm.environment.get('csrf_token') || pm.environment.get('csrf_token') === 'your-csrf-token-here') {",
					"    pm.environment.set('csrf_token', 'csrf-token-' + Math.random().toString(36).substr(2, 9));",
					"    console.log('ℹ️  Generated placeholder CSRF token');",
					"}",
					"",
					"// Auto-generate session ID if not set (for web interface)",
					"if (!pm.environment.get('session_id') || pm.environment.get('session_id') === 'your-session-id-here') {",
					"    pm.environment.set('session_id', 'session-' + Math.random().toString(36).substr(2, 9));",
					"    console.log('ℹ️  Generated placeholder session ID');",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// ====================================",
					"// TEST SCRIPT - Global Response Handler",
					"// ====================================",
					"",
					"// Auto-extract token from auth response",
					"if (pm.response.json() && pm.response.json().token) {",
					"    pm.environment.set('active_token', pm.response.json().token);",
					"    pm.environment.set('token_expires_at', pm.response.json().expires_at);",
					"    pm.environment.set('token_created_at', pm.response.json().created_at);",
					"    pm.environment.set('token_lifetime_minutes', pm.response.json().lifetime_minutes);",
					"    console.log('✓ Token automatically extracted from response');",
					"}",
					"",
					"// Auto-extract key from key generation response",
					"if (pm.response.json() && pm.response.json().key) {",
					"    pm.environment.set('api_key', pm.response.json().key);",
					"    console.log('✓ API Key automatically extracted from response');",
					"}",
					"",
					"// Auto-extract user_id if present in response",
					"if (pm.response.json() && pm.response.json().user_id) {",
					"    pm.environment.set('user_id', pm.response.json().user_id);",
					"    console.log('✓ User ID automatically extracted from response');",
					"}",
					"",
					"// Log response status for debugging",
					"if (pm.response.code !== 200 && pm.response.code !== 201) {",
					"    console.log('⚠️  Response Status: ' + pm.response.code);",
					"} else {",
					"    console.log('✓ Response Status: ' + pm.response.code);",
					"}"
				]
			}
		}
	],
